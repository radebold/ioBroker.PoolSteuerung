{
  "type": "tabs",
  "width": "900px",
  "items": {
    "general": {
      "type": "panel",
      "label": "ALLGEMEIN",
      "items": {
        "h1": {
          "type": "header",
          "text": "Grundeinstellungen",
          "size": 2
        },
        "i1": {
          "type": "staticText",
          "text": "Globale Einstellungen f\u00fcr die Poolsteuerung.",
          "style": {
            "opacity": 0.8,
            "fontSize": 12,
            "paddingBottom": 10
          }
        },
        "adapterEnabled": {
          "type": "checkbox",
          "label": "Adapter aktiv",
          "newLine": true,
          "help": "Schaltet die komplette Poolautomatik ein oder aus."
        },
        "debugMode": {
          "type": "checkbox",
          "label": "Debug-Modus",
          "newLine": true,
          "help": "Schreibt zus\u00e4tzliche Entscheidungen und Werte ins Log."
        },
        "simulateMode": {
          "type": "checkbox",
          "label": "Simulationsmodus",
          "newLine": true,
          "help": "Es werden keine echten Aktoren geschaltet."
        },
        "pollIntervalMin": {
          "type": "number",
          "label": "Pr\u00fcfintervall (Minuten)",
          "newLine": true,
          "help": "Zeitabstand zwischen den Steuerzyklen."
        },
        "poolDiameterM": {
          "type": "number",
          "label": "Pooldurchmesser (m)",
          "newLine": true,
          "help": "Innendurchmesser des Pools."
        },
        "poolWaterHeightM": {
          "type": "number",
          "label": "Wasserh\u00f6he (m)",
          "newLine": true,
          "help": "Tats\u00e4chliche Wasserh\u00f6he."
        },
        "poolVolumeM3": {
          "type": "number",
          "label": "Poolvolumen (m\u00b3)",
          "newLine": true,
          "help": "Optional fixes Volumen f\u00fcr Berechnungen."
        }
      }
    },
    "ph": {
      "type": "panel",
      "label": "PH-DOSIERUNG",
      "items": {
        "h1": {
          "type": "header",
          "text": "Sensor & Aktor",
          "size": 2
        },
        "i1": {
          "type": "staticText",
          "text": "Hier werden pH-Sensor und Dosierpumpe eingetragen.",
          "style": {
            "opacity": 0.8,
            "fontSize": 12,
            "paddingBottom": 10
          }
        },
        "phStateId": {
          "type": "text",
          "label": "State-ID pH",
          "newLine": true,
          "help": "Datenpunkt f\u00fcr den aktuellen pH-Wert."
        },
        "phDoseEnableStateId": {
          "type": "text",
          "label": "State-ID pH Freigabe",
          "newLine": true,
          "help": "Boolescher Freigabe-Datenpunkt f\u00fcr die Dosierung."
        },
        "phPumpSocketStateId": {
          "type": "text",
          "label": "Dosierpumpe",
          "newLine": true,
          "help": "Schaltbarer Datenpunkt der pH-Dosierpumpe."
        },
        "h2": {
          "type": "header",
          "text": "Regelung",
          "size": 2
        },
        "i2": {
          "type": "staticText",
          "text": "Diese Werte steuern die Berechnung und Begrenzung der Dosiermenge.",
          "style": {
            "opacity": 0.8,
            "fontSize": 12,
            "paddingBottom": 10
          }
        },
        "phEnabled": {
          "type": "checkbox",
          "label": "pH aktiv",
          "newLine": true,
          "help": "Aktiviert die pH-Automatik."
        },
        "phTarget": {
          "type": "number",
          "label": "Soll-pH",
          "newLine": true,
          "help": "Zielwert f\u00fcr die pH-Regelung."
        },
        "phMinDelta": {
          "type": "number",
          "label": "Minimale Abweichung",
          "newLine": true,
          "help": "Erst ab dieser Abweichung wird dosiert."
        },
        "phPumpFlowMlMin": {
          "type": "number",
          "label": "F\u00f6rdermenge ml/min",
          "newLine": true,
          "help": "F\u00f6rdermenge der Dosierpumpe."
        },
        "phLiquidFactorPercent": {
          "type": "number",
          "label": "Fl\u00fcssigfaktor %",
          "newLine": true,
          "help": "Sicherheitsfaktor f\u00fcr die Dosiermenge."
        },
        "phMaxDoseMlPerCycle": {
          "type": "number",
          "label": "Max ml pro Zyklus",
          "newLine": true,
          "help": "Begrenzt die Dosierung pro Lauf."
        },
        "phMaxRuntimeSec": {
          "type": "number",
          "label": "Max Laufzeit Sek",
          "newLine": true,
          "help": "Maximale Pumpenlaufzeit pro Dosierung."
        },
        "phOnlyWhenPumpRunning": {
          "type": "checkbox",
          "label": "Nur wenn Pumpe l\u00e4uft",
          "newLine": true,
          "help": "Dosierung nur bei laufender Umw\u00e4lzpumpe."
        },
        "phDoseTimes": {
          "type": "text",
          "label": "Pr\u00fcfzeiten",
          "newLine": true,
          "help": "Kommagetrennte Uhrzeiten, z. B. 12:00,15:00."
        }
      }
    },
    "chlor": {
      "type": "panel",
      "label": "CHLORINATOR",
      "items": {
        "h1": {
          "type": "header",
          "text": "Sensor & Aktor",
          "size": 2
        },
        "i1": {
          "type": "staticText",
          "text": "Hier werden ORP-Sensor und Chlorinator eingetragen.",
          "style": {
            "opacity": 0.8,
            "fontSize": 12,
            "paddingBottom": 10
          }
        },
        "orpStateId": {
          "type": "text",
          "label": "State-ID ORP",
          "newLine": true,
          "help": "Datenpunkt f\u00fcr den aktuellen Redox-/ORP-Wert."
        },
        "chlorinatorSocketStateId": {
          "type": "text",
          "label": "Chlorinator",
          "newLine": true,
          "help": "Schaltbarer Datenpunkt des Chlorinators."
        },
        "h2": {
          "type": "header",
          "text": "Regelung",
          "size": 2
        },
        "i2": {
          "type": "staticText",
          "text": "Diese Werte steuern die automatische Ein-/Aus-Regelung des Chlorinators.",
          "style": {
            "opacity": 0.8,
            "fontSize": 12,
            "paddingBottom": 10
          }
        },
        "chlorinatorEnabled": {
          "type": "checkbox",
          "label": "Chlorinator aktiv",
          "newLine": true,
          "help": "Aktiviert die Chlorinator-Logik."
        },
        "chlorinatorAutoEnabled": {
          "type": "checkbox",
          "label": "ORP-Automatik aktiv",
          "newLine": true,
          "help": "Schaltet automatisch nach ORP."
        },
        "chlorinatorOnlyWhenPumpRunning": {
          "type": "checkbox",
          "label": "Nur bei laufender Pumpe",
          "newLine": true,
          "help": "Chlorinator nur mit Umw\u00e4lzung."
        },
        "orpOn": {
          "type": "number",
          "label": "ORP EIN bei <=",
          "newLine": true,
          "help": "Unterhalb dieses Werts wird eingeschaltet."
        },
        "orpOff": {
          "type": "number",
          "label": "ORP AUS bei >",
          "newLine": true,
          "help": "Oberhalb dieses Werts wird ausgeschaltet."
        },
        "chlorinatorMinOnMin": {
          "type": "number",
          "label": "Mindest-EIN-Zeit (Min)",
          "newLine": true,
          "help": "Verhindert zu schnelles Ausschalten."
        },
        "chlorinatorMinOffMin": {
          "type": "number",
          "label": "Mindest-AUS-Zeit (Min)",
          "newLine": true,
          "help": "Verhindert zu schnelles Wiedereinschalten."
        },
        "chlorinatorStopTime": {
          "type": "text",
          "label": "Abschaltzeit",
          "newLine": true,
          "help": "Optionale feste Abschaltzeit, z. B. 15:30."
        }
      }
    },
    "pump": {
      "type": "panel",
